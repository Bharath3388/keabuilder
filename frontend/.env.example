# KeaBuilder Frontend — Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard for production

# Backend URL (Railway deployed URL)
# Local dev: leave empty (defaults to http://localhost:8000)
# Production: set to your Railway backend URL
NEXT_PUBLIC_API_URL=

# API key for authenticated requests (must match backend API_KEYS)
NEXT_PUBLIC_API_KEY=
