# KeaBuilder Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# LLM Provider (Free: Groq with Llama 3.3)
# Get free API key at: https://console.groq.com
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Ollama for local inference (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =============================================================================
# Image Generation (Free: Hugging Face Inference API)
# Get free token at: https://huggingface.co/settings/tokens
# =============================================================================
HF_API_TOKEN=your_huggingface_token_here
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# =============================================================================
# Voice/TTS (Free: edge-tts — no API key needed)
# =============================================================================
TTS_PROVIDER=edge-tts
TTS_DEFAULT_VOICE=en-US-AriaNeural

# =============================================================================
# Storage (Local filesystem for dev, S3 for prod)
# =============================================================================
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage
# For production:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=keabuilder-assets
# AWS_REGION=us-east-1

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./keabuilder.db
# For production:
# DATABASE_URL=postgresql://user:pass@localhost:5432/keabuilder

# =============================================================================
# Redis (for caching and job queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# ChromaDB (Vector store — runs embedded, no server needed)
# =============================================================================
CHROMA_PERSIST_DIR=./storage/chromadb

# =============================================================================
# App Settings
# =============================================================================
APP_NAME=KeaBuilder
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
# For production (Vercel frontend URL):
# CORS_ORIGINS=https://your-app.vercel.app

# API Authentication — comma-separated API keys
# API_KEYS=your-secret-api-key-here

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
